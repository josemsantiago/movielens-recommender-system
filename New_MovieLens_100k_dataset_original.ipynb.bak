      "metadata": {
        "id": "WzZLDJ8pQSKX"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# check for missing values\n",
        "# print a heading for the ratings results\n",
        "print(\"Missing values in ratings:\")\n",
        "\n",
        "# count missing values in every ratings column\n",
        "print(ratings.isnull().sum())\n",
        "\n",
        "\n",
        "# print a heading for the movie-information results\n",
        "print(\"\\nMissing values in movie information:\")\n",
        "\n",
        "# count missing values in the item ID and title columns\n",
        "print(movies.isnull().sum())"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "XF4kQO-DQTOl",
