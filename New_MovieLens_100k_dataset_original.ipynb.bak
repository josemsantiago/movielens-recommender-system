            "dtype: object\n",
            "\n",
            "Movie data types:\n",
            "item_id     int64\n",
            "title      object\n",
            "dtype: object\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# rating values\n",
        "# movieLens ratings should range from 1 through 5.\n",
        "# find, sort, and display every rating value in the dataset\n",
        "print(\n",
        "    \"Rating values:\",\n",
        "    sorted(ratings[\"rating\"].unique())\n",
        ")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "KwJKgIyIQkmH",
        "outputId": "0006a70c-4a14-4af5-a4ae-e6c641ae813d"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Rating values: [np.int64(1), np.int64(2), np.int64(3), np.int64(4), np.int64(5)]\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Clean and format data**"
      ],
      "metadata": {
        "id": "R_A6fTVDRKKS"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# create copies and clean the tables\n",
        "# create a copy of the ratings table for cleaning\n",
        "ratings_clean = ratings.copy()\n",
        "\n",
        "# create a copy of the movie table for cleaning\n",
        "movies_clean = movies.copy()\n",
        "\n",
        "\n",
        "# remove rating rows containing missing values\n",
        "ratings_clean = ratings_clean.dropna()\n",
        "\n",
        "\n",
        "# remove movie rows missing an item ID or title\n",
        "movies_clean = movies_clean.dropna(\n",
        "    subset=[\"item_id\", \"title\"]\n",
        ")\n",
        "\n",
        "\n",
        "# remove completely duplicated rating records\n",
        "ratings_clean = ratings_clean.drop_duplicates()\n",
        "\n",
        "\n",
        "# keep the first movie record for each item ID\n",
        "movies_clean = movies_clean.drop_duplicates(\n",
        "    subset=[\"item_id\"],\n",
        "    keep=\"first\"\n",
        ")"
      ],
      "metadata": {
        "id": "CLzSqSPEROdw"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# confirm the data types and convert ratings\n",
        "# print a heading for the data types before conversion\n",
        "print(\"Ratings data types before conversion:\")\n",
        "\n",
        "# show the current ratings data types\n",
        "print(ratings_clean.dtypes)\n",
        "\n",
        "\n",
        "# print the movie data types for confirmation\n",
        "print(\"\\nMovie data types:\")\n",
        "\n",
        "# show the current movie data types\n",
        "print(movies_clean.dtypes)\n",
        "\n",
        "\n",
        "# convert only the rating column from integers to floats\n",
        "ratings_clean[\"rating\"] = (\n",
        "    ratings_clean[\"rating\"].astype(float)\n",
        ")\n",
        "\n",
        "\n",
        "# print a heading for the final data types\n",
        "print(\"\\nFinal ratings data types:\")\n",
        "\n",
        "# confirm the ratings data types after conversion\n",
        "print(ratings_clean.dtypes)"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "GMxFncYzRRww",
        "outputId": "a63acbae-9fca-4c90-d5cf-421fad4bd14e"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Ratings data types before conversion:\n",
            "user_id      int64\n",
            "item_id      int64\n",
            "rating       int64\n",
            "timestamp    int64\n",
            "dtype: object\n",
            "\n",
            "Movie data types:\n",
            "item_id     int64\n",
            "title      object\n",
            "dtype: object\n",
            "\n",
            "Final ratings data types:\n",
            "user_id        int64\n",
            "item_id        int64\n",
            "rating       float64\n",
            "timestamp      int64\n",
            "dtype: object\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# compare data before and after cleaning\n",
        "# show the number of original rating records\n",
        "print(\n",
        "    \"Original rating rows:\",\n",
        "    len(ratings)\n",
        ")\n",
        "\n",
        "\n",
        "# show the number of rating records after cleaning\n",
        "print(\n",
        "    \"Clean rating rows:\",\n",
        "    len(ratings_clean)\n",
        ")\n",
        "\n",
        "\n",
        "# calculate and show the number of removed records\n",
        "print(\n",
        "    \"Rating rows removed:\",\n",
        "    len(ratings) - len(ratings_clean)\n",
        ")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "Y1q4w0sZSJwN",
        "outputId": "dcdc3749-5045-48ab-a895-6049b7836a23"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Original rating rows: 100000\n",
            "Clean rating rows: 100000\n",
            "Rating rows removed: 0\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# merge ratings and movie titles\n",
        "# connect each rating with its corresponding movie title\n",
        "data = ratings_clean.merge(\n",
        "    movies_clean,\n",
        "    on=\"item_id\",\n",
        "    how=\"left\"\n",
        ")\n",
        "\n",
        "\n",
        "# show the first five combined records\n",
        "data.head()"
      ],
