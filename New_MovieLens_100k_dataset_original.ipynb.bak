            ],
            "image/png": "\n"
          },
          "metadata": {}
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "**Histogram per user results**\n",
        "\n",
        "The x-axis shows the number of ratings submitted.\n",
        "The y-axis shows how many users fall within each range.\n",
        "\n",
        "The chart shows that most users did not submit a lot of reviews, but a small number of users submitted several hundred. This made a right-skewed distribution, with a long tail extending toward the higher rating counts.\n"
      ],
      "metadata": {
        "id": "5OwKLgCJirxV"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# group the records by movie and count each movie's ratings\n",
        "ratings_per_movie = (\n",
        "    data\n",
        "    .groupby(\"item_id\")\n",
        "    .size()\n",
        ")\n",
        "\n",
        "\n",
        "# display summary statistics for ratings received per movie\n",
        "print(\"Summary of ratings received per movie:\")\n",
        "print(ratings_per_movie.describe())\n",
        "\n",
        "\n",
        "# create a chart that is eight inches wide and five inches tall\n",
        "plt.figure(figsize=(8, 5))\n",
        "\n",
        "\n",
        "# create a histogram using 30 intervals\n",
        "plt.hist(\n",
        "    ratings_per_movie,\n",
        "    bins=30\n",
        ")\n",
        "\n",
        "\n",
        "# add a title describing the chart\n",
        "plt.title(\"Number of Ratings Received per Movie\")\n",
        "\n",
        "\n",
        "# label the horizontal axis\n",
        "plt.xlabel(\"Number of Ratings\")\n",
        "\n",
        "\n",
        "# label the vertical axis\n",
        "plt.ylabel(\"Number of Movies\")\n",
        "\n",
        "\n",
        "# display the completed chart\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 661
        },
        "id": "Pu-6Ngt0S17n",
        "outputId": "62d217e5-510b-4625-f8a2-cae7ee440cf2"
      },
      "execution_count": null,
