    {
      "cell_type": "code",
      "source": [
        "# visualize the distribution of ratings\n",
        "# the horizontal axis shows the rating value, and the vertical axis shows the number of ratings\n",
        "\n",
        "# Count how many times each rating value appears\n",
        "rating_counts = (\n",
        "    data[\"rating\"]\n",
        "    .value_counts()\n",
        "    .sort_index()\n",
        ")\n",
        "\n",
        "\n",
        "# show the numerical rating counts\n",
        "print(\"Number of times each rating was given:\")\n",
        "print(rating_counts)\n",
        "\n",
        "\n",
        "# make a chart that is eight inches wide and five inches tall\n",
        "plt.figure(figsize=(8, 5))\n",
        "\n",
        "\n",
        "# make one bar for each rating value\n",
        "plt.bar(\n",
        "    rating_counts.index,\n",
        "    rating_counts.values\n",
        ")\n",
        "\n",
        "\n",
        "# add a title describing the chart\n",
        "plt.title(\"Distribution of Movie Ratings\")\n",
        "\n",
        "\n",
        "# label the horizontal axis\n",
        "plt.xlabel(\"Rating\")\n",
        "\n",
        "\n",
        "# label the vertical axis\n",
        "plt.ylabel(\"Number of Ratings\")\n",
        "\n",
        "\n",
        "# show all five rating values on the horizontal axis\n",
        "plt.xticks([1, 2, 3, 4, 5])\n",
        "\n",
        "\n",
        "# show the completed chart\n",
        "plt.show()"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 626
        },
        "id": "NGqAZLSdSrlV",
        "outputId": "4cad32e1-e362-47fc-e4c2-a8fe4fa695d1"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
