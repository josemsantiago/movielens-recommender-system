    {
      "cell_type": "code",
      "source": [
        "\n",
        "# show highly rated movies with at least 50 ratings\n",
        "# keep only movies that received at least 50 ratings\n",
        "movies_with_50_ratings = movie_summary[\n",
        "    movie_summary[\"number_of_ratings\"] >= 50\n",
        "]\n",
        "\n",
        "\n",
        "# sort the remaining movies by average rating\n",
        "highest_rated_movies = (\n",
        "    movies_with_50_ratings\n",
        "    .sort_values(\n",
        "        \"average_rating\",\n",
        "        ascending=False\n",
        "    )\n",
        "    .head(10)\n",
        ")\n",
        "\n",
        "\n",
        "# show the ten highest-rated qualifying movies\n",
        "highest_rated_movies"
      ],
